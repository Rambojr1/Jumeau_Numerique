<?xml version="1.0"?>
<robot name="hexapode">

  <!-- Corps principal -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.30 0.18 0.05"/>
      </geometry>
    </visual>
  </link>

  <!-- Coxa -->
  <link name="leg_1_coxa_link">
    <visual>
      <origin xyz="0.04 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.025 0.025"/>
      </geometry>
    </visual>
  </link>

  <!-- Femur -->
  <link name="leg_1_femur_link">
    <visual>
      <origin xyz="0.06 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.022 0.022"/>
      </geometry>
    </visual>
  </link>

  <!-- Tibia -->
  <link name="leg_1_tibia_link">
    <visual>
      <origin xyz="0.07 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.14 0.020 0.020"/>
      </geometry>
    </visual>
  </link>

  <!-- Joint Coxa -->
  <joint name="leg_1_coxa_joint" type="revolute">
    <parent link="base_link"/>
    <child link="leg_1_coxa_link"/>

    <origin xyz="0.10 0.08 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>

    <limit lower="-1.57"
           upper="1.57"
           effort="10"
           velocity="1"/>
  </joint>

  <!-- Joint Femur -->
  <joint name="leg_1_femur_joint" type="revolute">
    <parent link="leg_1_coxa_link"/>
    <child link="leg_1_femur_link"/>

    <origin xyz="0.08 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>

    <limit lower="-1.57"
           upper="1.57"
           effort="10"
           velocity="1"/>
  </joint>

  <!-- Joint Tibia -->
  <joint name="leg_1_tibia_joint" type="revolute">
    <parent link="leg_1_femur_link"/>
    <child link="leg_1_tibia_link"/>

    <origin xyz="0.12 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>

    <limit lower="-1.57"
           upper="1.57"
           effort="10"
           velocity="1"/>
  </joint>

</robot>